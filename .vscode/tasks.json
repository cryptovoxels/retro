{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Codespaces: pnpm install && dev",
      "type": "shell",
      "command": "test -z \"${CODESPACES:-}\" && exit 0; pnpm install && pnpm run dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
