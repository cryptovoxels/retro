{
  "name": "Retro Voxels",
  "dockerComposeFile": ".devcontainer/docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/retro",
  "containerEnv": {
    "DATABASE_URL": "postgres://voxels:voxels@db:5432/voxels"
  },
  "forwardPorts": [9000, 9100, 9200, 3780, 5432],
  "portsAttributes": {
    "9000": {
      "label": "HTTP API",
      "protocol": "http",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "9100": {
      "label": "webpack client",
      "protocol": "http",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "9200": {
      "label": "webpack web",
      "protocol": "http",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "3780": {
      "label": "multiplayer",
      "protocol": "http",
      "onAutoForward": "notify",
      "visibility": "public"
    },
    "5432": { "label": "postgres", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "task.allowAutomaticTasks": "on",
        "workbench.colorTheme": "Monaco Dark",
        "editor.fontFamily": "'Monaco', 'Courier New', monospace",
        "editor.fontSize": 14,
        "editor.bracketPairColorization.enabled": true,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        }
      },
      "extensions": [
        "visualstudioexptteam.vscodeintellicode",
        "GitHub.copilot",
        "be5invis.theme-monaco",
        "mrdoob.glsl",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ],
      "openFiles": ["README.md", "src/index.tsx"]
    }
  },
  "postCreateCommand": "pnpm install && bash .devcontainer/setup-db.sh"
}
